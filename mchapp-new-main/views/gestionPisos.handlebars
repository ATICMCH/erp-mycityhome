<style>
      h5 {
            color: #f18420;
            font-weight: bold;
      }

      .show {
            display: block;
      }

      .hide {
            display: none;
      }

      button.btn-enviar {
            margin-top: 0;
            margin-left: 1%;
      }

      button {
            margin-top: 0%;
      }

      #accion,
      #location,
      #typecard,
      #typecode {
            width: 100%;
            padding-top: 0.3rem;
            padding-bottom: 0.3rem;
            padding-left: 0.5rem;
            font-size: 1rem;
      }

      div.txt-left {
            text-align: left;
      }

      span.not-exist {
            font-size: 1.8rem;
            font-weight: normal;
      }

      .mt-2 {
            padding-bottom: 20px;
      }

      .sincronzarTimeStamp {
            margin-top: 10px;
      }

      .btns-cp {
            margin-bottom: 5px;
      }

      img.link-luz {
            width: 70px;
            cursor: pointer;
            top: -10px;
            position: relative;
      }

      span.txt-link-luz {
            font-size: 14px;
            margin-left: -20px;
            margin-top: 35px;
            position: absolute;
      }

      @media screen and (max-width: 600px) {
            h1.head-title {
                  margin-top: 25px;
                  font-size: 20px;
            }

            span.txt-link-luz {
                  font-size: 12px;
            }
      }

      .modal {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            display: none;
            background: rgba(0, 0, 0, 0.5);
            justify-content: center;
            align-items: center;
            z-index: 1050;
      }

      .modal .modal-dialog {
            background: #fff;
            border-radius: 8px;
            overflow: hidden;
            max-width: 500px;
            width: 90%;
      }

      .modal .modal-header {
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 1rem;
            position: relative;
      }

      .modal .modal-header .modal-title {
            font-size: 1.5rem;
            text-align: center;
            margin: 0 auto;
      }

      .modal .modal-header .btn-close {
            position: absolute;
            right: 1rem;
            top: 1rem;
      }

      .modal.show {
            display: flex;
      }
</style>

<div class="container">

      <img src="https://i.ibb.co/FxhfMzh/Logo-4.png" width="50%" class="mx-auto d-block" id="icon" alt="MyCityHome" />

      {{#if existDevice }}
      <h1 class="text-center pb-3 head-title">{{etiqueta}}</h1>
      {{else}}
      <h1 class="text-center pb-3 head-title">{{etiqueta}} <span class="not-exist text-danger">(No esta disponible!!)</span></h1>
      {{/if}}

      {{#if (eq etiqueta "Hoyo2") }}
      <div class="alert alert-warning text-center" role="alert" style="font-size:1.2rem; font-weight:bold;">
            ESTE PISO SE ABRE POR LA APP TTLOCK.<br>
            Más información: <a href="https://drive.google.com/drive/folders/1r2VndaRT9XhwFoQzbijHuSGoMqYzIk88" target="_blank">Ver instrucciones aquí</a>
      </div>
      {{/if}}

      <div class="row d-flex justify-content-around">

            <div class="col-md shadow card rounded m-2">
                  <div class="card-tittle p-2 m-2 text-center">
                        <h5>Control del piso</h5>
                  </div>

                  <div id="alertOK_CP" class="alert alert-success alert-dismissible fade hide" role="alert">
                        <b id="msgOK_CP">OK.</b>
                        <button type="button" class="btn-close" onclick="Util.closeAlert('alertOK_CP');" aria-label="Close"></button>
                  </div>
                  <div id="alertKO_CP" class="alert alert-danger alert-dismissible fade hide" role="alert">
                        <b id="msgKO_CP">Error.</b>
                        <button type="button" class="btn-close" onclick="Util.closeAlert('alertKO_CP');" aria-label="Close"></button>
                  </div>

                  <div class="mb-3 text-center">
                        <div class="alert txt-left fst-italic text-muted" role="alert">
                              Opciones disponibles para este piso
                        </div>
                        
                        <div>
                              {{#if sonoffExist}}
                                    {{#each lDevicesSonoff}}
                                    <div id="btn-sonoff-{{id}}" class="hide">
                                          <img id="link-luz-{{id}}" class="link-luz"
                                                onclick="GestionPiso.actionToggleDevice('{{stateSONOFF}}', {{id}});"
                                                src="/img/{{imgStateSONOFF}}" />
                                          <span id="txt-link-luz-{{id}}" class="txt-link-luz">[ {{nameStateSONOFF}} ]</span>
                                    </div>
                                    <div id="wait-sonoff-{{id}}" class="show">
                                          <span class="spinner-border spinner-border" role="status" aria-hidden="true"></span>
                                    </div>
                                    <br />
                                    {{/each}}
                              {{/if}}
                        </div>

                        {{#if isWelock }}
                        <button type="button" class="btn btn-primary btn-enviar btns-cp"
                              onclick="GestionPiso.actionOpenLock({{idDeviceLock}});">Abrir puerta</button>
                        <div class="mb-3 text-center sincronzarTimeStamp">
                              <button type="button" id="btnSyncTime" class="btn btn-primary btn-enviar btns-cp"
                                    onclick="GestionPiso.actionSyncTime({{idDeviceLock}});">Sincronizar hora</button>
                        </div>
                        {{/if}}

                        {{#if isPortal }}
                        <button type="button" class="btn btn-success btn-enviar btns-cp"
                              onclick="GestionPiso.actionOpenPortal({{idDevicePortal}});">Abrir portal</button>
                        {{/if}}

                        <button type="button" class="btn btn-warning btn-enviar btns-cp"
                              onclick="openModal()">Mirilla</button>
                  </div>
            </div>

            <div class="col-md shadow card rounded m-2">
                  <div class="card-tittle p-2 m-2 text-center">
                        <h5 class="text">Cambiar código</h5>
                  </div>

                  <form method="POST" action="javascript:void(0);" class="form">
                        <div id="alertOK_CC" class="alert alert-success alert-dismissible fade hide" role="alert">
                              <b id="msgOK_CC">OK.</b>
                              <button type="button" class="btn-close" onclick="Util.closeAlert('alertOK_CC');" aria-label="Close"></button>
                        </div>
                        <div id="alertKO_CC" class="alert alert-danger alert-dismissible fade hide" role="alert">
                              <b id="msgKO_CC">Error.</b>
                              <button type="button" class="btn-close" onclick="Util.closeAlert('alertKO_CC');" aria-label="Close"></button>
                        </div>

                        <div class="alert txt-left fst-italic text-muted" role="alert">
                              Ingrese los días de vigencia para generar el código WeLock.
                        </div>

                        <input type="hidden" id="codigo" value="123456">

                        {{#if showFieldTypeCode }}
                        <div class="mb-3">
                              <label for="typecode" class="form-label fw-bold">Tipo Código <span class="text-danger">*</span></label>
                              <select id="typecode" class="form-select form-select-lg mb-3">
                                    <option value="NA">Seleccionar</option>
                                    {{#each lTypesCodesDB}}
                                    <option value="{{id}}">{{nombre}}</option>
                                    {{/each}}
                              </select>
                        </div>
                        {{/if}}

                        <div class="mb-3">
                              <label for="vigencia" class="form-label font-weight-bold fw-bold">Vigencia en días <span class="text-danger">*</span></label>
                              <input type="number" class="form-control" id="vigencia" placeholder="Mínimo 1 día" />
                        </div>

                        <div class="mb-3 text-center">
                              {{#if isWelock }}
                              <button type="submit" class="btn btn-primary btn-enviar"
                                    onclick="GestionPiso.actionNewCode({{idDeviceLock}});">Crear Código WeLock</button>
                              {{/if}}
                        </div>
                  </form>
            </div>

            <div style="display:none">
                  <select id="accion"><option value="0"></option></select>
                  <input type="text" id="idQr">
                  <select id="typecard"><option value="NA"></option></select>
                  <select id="location"><option value="NA"></option></select>
                  <input type="text" id="qr">
            </div>

      </div>

      <div class="mt-2">
            <button type="button" class="btn btn-secondary btn-enviar" onclick="GestionPiso.back('{{pathBack}}');">
                  < Atrás</button>
      </div>
</div>

<div class="modal fade" id="modalEspera" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1">
      <div class="modal-dialog modal-sm">
            <div class="modal-content">
                  <div class="modal-body text-center">
                        <div class="spinner-border" role="status"></div>
                        &nbsp;Espere...
                  </div>
            </div>
      </div>
</div>

<div id="mirillaModal" class="modal hide" tabindex="-1">
      <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                  <div class="modal-header">
                        <h1 class="modal-title">{{etiqueta}}</h1>
                  </div>
                  <div class="modal-body" style="text-align: center;">
                        <img id="videoStream" alt="Cámara en vivo" style="width: 100%; max-height: 400px; object-fit: contain;" />
                  </div>
                  <div class="modal-footer">
                        <button type="button" class="btn btn-warning" onclick="openMirillaModal()">Conectar</button>
                        <button type="button" class="btn btn-secondary" onclick="closeMirillaModal()">Cerrar</button>
                  </div>
            </div>
      </div>
</div>




<script src="https://cdn.socket.io/4.4.1/socket.io.js"></script>
<script>
      // Inicialización de GestionPiso con los datos pasados desde Handlebars
      GestionPiso.init("{{codeDevice}}", "{{urlServer}}", "{{user}}", "{{rolUser}}", {{ idPiso }}, {{ lIdsDevices }});
</script>



<script>

      function openModal() {
            console.log("Abriendo el modal de Mirilla");
            const modal = document.getElementById('mirillaModal');
            modal.classList.remove('hide');
            modal.classList.add('show');
      }
      function closeModal() {
            // Enviar un mensaje al servidor WebSocket para que el cliente móvil detenga la transmisión

            console.log("Cerrando el modal de Mirilla");

            // Cerrar el modal
            const modal = document.getElementById('mirillaModal');
            modal.classList.remove('show');
            modal.classList.add('hide');
      }



      let mirillaSocket = null;  // Definimos el socket específico para el modal

      // Abrir el modal y conectar al servidor WebSocket de video
      async function openMirillaModal() {
            try {
                  // Iniciar el servidor de la mirilla
                  const response = await fetch('/start-mirilla', { method: 'POST' });
                  const result = await response.json();
                  console.log(result.message);

                  // Obtener el valor de {{etiqueta}} (ID que se pasa desde Handlebars)
                  const id = "{{etiqueta}}";  // Este es el valor que se obtiene del servidor al renderizar la página
                  console.log(`ID de la etiqueta: ${id}`);

                  // Conectar a un WebSocket independiente para la transmisión de video
                  mirillaSocket = io('wss://mchapp.fly.dev', { transports: ['websocket'] });
                  mirillaSocket.on('connect', () => {
                        console.log('Conectado al servidor WebSocket de video.');
                  });

                  // Enviar el ID al servidor WebSocket
                  mirillaSocket.emit('send-id', id);

                  // Escuchar la respuesta del servidor para verificar el ID
                  mirillaSocket.on('receive-id', (receivedID) => {
                        if (receivedID === id) {
                              console.log("ID coincide, iniciar transmisión de video...");
                              startStreaming(); // Llama a la función para iniciar la transmisión de video
                        } else {
                              console.log("ID no coincide, no se puede iniciar transmisión");
                        }
                  });

                  // Recibir datos de video y mostrarlos en el modal
                  mirillaSocket.on('video-stream', (data) => {
    console.log('Datos de video recibidos');
    const videoStreamElement = document.getElementById('videoStream');
    if (videoStreamElement && data && data.encodedImage) {
        videoStreamElement.src = `data:image/jpeg;base64,${data.encodedImage}`;
    }
});


                  // Manejar errores y desconexiones
                  mirillaSocket.on('disconnect', () => {
                        console.log('Desconectado del servidor WebSocket de video.');
                  });

                  mirillaSocket.on('connect_error', (error) => {
                        console.error('Error al conectar al servidor WebSocket de video:', error);
                  });

                  // Mostrar el modal
                  const modal = document.getElementById('mirillaModal');
                  if (modal) {
                        modal.classList.remove('hide');
                        modal.classList.add('show');
                  }
            } catch (error) {
                  console.error('Error al iniciar el servidor de la Mirilla:', error);
            }
      }

      function startStreaming() {
            // Aquí puede ir tu lógica para iniciar la transmisión de la cámara
            console.log("Iniciando la transmisión de video...");
            // Asegúrate de tener implementada la lógica para empezar a transmitir imágenes
      }

      // Cerrar el modal y desconectar del servidor WebSocket de video
      async function closeMirillaModal() {
            try {
                  // Asegúrate de que el socket esté conectado antes de emitir el evento
                  if (mirillaSocket && mirillaSocket.connected) {
                        // Enviar el evento para detener la transmisión antes de cualquier otra acción
                        console.log("Enviando stop-video-streaming al servidor WebSocket");
                        mirillaSocket.emit('stop-video-streaming');
                  } else {
                        console.log("Socket no está conectado, no se pudo emitir el evento.");
                  }

                  // Detener el servidor de la Mirilla
                  const response = await fetch('/stop-mirilla', { method: 'POST' });
                  const result = await response.json();
                  console.log(result.message);  // Mostrar mensaje recibido del servidor

                  // Cerrar el socket de video si está conectado
                  if (mirillaSocket && mirillaSocket.connected) {
                        // Eliminar todos los eventos asociados al socket
                        mirillaSocket.off('video-stream');  // Eliminar evento de transmisión de video
                        mirillaSocket.off('connect');       // Eliminar evento de conexión
                        mirillaSocket.off('disconnect');    // Eliminar evento de desconexión
                        mirillaSocket.off('connect_error'); // Eliminar evento de error de conexión

                        // Desconectar el socket
                        mirillaSocket.disconnect();
                        console.log('Socket de video desconectado.');

                        // Limpiar referencia
                        mirillaSocket = null;
                  }

                  // Ocultar el modal
                  const modal = document.getElementById('mirillaModal');
                  if (modal) {
                        modal.classList.remove('show');
                        modal.classList.add('hide');
                  }

                  // Recargar la página después de un breve retraso
                  setTimeout(() => {
                        window.location.reload();
                  }, 500);

            } catch (error) {
                  console.error('Error al detener el servidor de la Mirilla:', error);
            }
      }

</script>